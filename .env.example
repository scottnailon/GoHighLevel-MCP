# GoHighLevel MCP Server v2 — Configuration

# ---------------------------------------------------------------------------
# AUTHENTICATION (required)
# ---------------------------------------------------------------------------

# Your GoHighLevel Private Integration Token (PIT).
# Generate at: GHL → Settings → Private Integrations → Create new Integration
# Required scopes for full functionality:
#   contacts.readonly, contacts.write
#   conversations.readonly, conversations.write
#   conversations/message.readonly, conversations/message.write
#   calendars.readonly, calendars.write, calendars/events.readonly, calendars/events.write
#   opportunities.readonly, opportunities.write
#   custom-fields.readonly, custom-fields.write
#   workflows.readonly
#   forms.readonly
#   users.readonly, users.write
GHL_API_KEY=

# Your Sub-Account / Location ID. Get from GHL → Settings → Business Profile.
GHL_LOCATION_ID=

# ---------------------------------------------------------------------------
# API CONFIGURATION (optional, sensible defaults)
# ---------------------------------------------------------------------------

# API base URL. Almost never needs changing.
GHL_BASE_URL=https://services.leadconnectorhq.com

# API version header. Pin to a known-good version.
GHL_API_VERSION=2021-07-28

# HTTP request timeout in seconds.
GHL_TIMEOUT=30

# Maximum retries on rate-limit (429) and transient errors.
GHL_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# LOGGING (optional)
# ---------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR. Defaults to INFO.
# Note: stdio MCP servers log to stderr, not stdout.
GHL_LOG_LEVEL=INFO
