# GoHighLevel MCP Server v2 — Configuration

# ---------------------------------------------------------------------------
# AUTHENTICATION (required)
# ---------------------------------------------------------------------------

# Your GoHighLevel Private Integration Token (PIT).
# Generate at: GoHighLevel → Settings → Private Integrations → Create new Integration
# Required scopes for full functionality:
#   contacts.readonly, contacts.write
#   conversations.readonly, conversations.write
#   conversations/message.readonly, conversations/message.write
#   calendars.readonly, calendars.write, calendars/events.readonly, calendars/events.write
#   opportunities.readonly, opportunities.write
#   custom-fields.readonly, custom-fields.write
#   locations.readonly, locations.write
#   saas/locations.read, saas/location.write
#   snapshots.readonly, snapshots.write
#   workflows.readonly
#   forms.readonly
#   users.readonly, users.write
#   webhooks.readonly, webhooks.write
GHL_API_KEY=

# Default Sub-Account / Location ID. Most tools default to this if no
# location_id is passed. Get from GHL → Settings → Business Profile.
GHL_LOCATION_ID=

# ---------------------------------------------------------------------------
# AGENCY-SCOPED OPERATIONS (optional — auto-detected)
# ---------------------------------------------------------------------------

# Your Agency / Company ID, used by agency-level tools (sub-account
# management, snapshots, SaaS, companies, funnels).
#
# You normally do NOT need to set this. On startup the server reads it
# automatically from your location record, so agency tools just work as long
# as GHL_API_KEY and GHL_LOCATION_ID are valid.
#
# Set it explicitly only if you want to pin a specific agency or operate
# across multiple agencies. Find it in GHL → Agency Settings, or just start
# the server and read the "Agency/company ID auto-detected" line in the log.
GHL_COMPANY_ID=

# ---------------------------------------------------------------------------
# API CONFIGURATION (optional, sensible defaults)
# ---------------------------------------------------------------------------

# API base URL. Almost never needs changing.
GHL_BASE_URL=https://services.leadconnectorhq.com

# API version header. Pin to a known-good version.
GHL_API_VERSION=2021-07-28

# HTTP request timeout in seconds.
GHL_TIMEOUT=30

# Maximum retries on rate-limit (429) and transient errors.
GHL_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# LOGGING (optional)
# ---------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR. Defaults to INFO.
# Note: stdio MCP servers log to stderr, not stdout.
GHL_LOG_LEVEL=INFO
